# PL TOTW Builder — Environment Variables
# Copy this to .claude/settings.local.json and fill in values
# Never commit actual secrets to git

# API-Football (https://www.api-football.com)
API_FOOTBALL_KEY=your_api_football_key_here

# Google OAuth (https://console.cloud.google.com)
# Required for Google Slides and Gmail MCP
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here

# These are set automatically in .claude/settings.json
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# PL_LEAGUE_ID=39
# PL_SEASON=2025
# PROJECT_EMAIL=24hrnts@gmail.com

